{
  "name": "swag-labs-playwright-bdd-ts",
  "version": "1.0.0",
  "description": "Automação E2E do Swag Labs (SauceDemo) usando Playwright + TypeScript + Playwright BDD (Gherkin).",
  "scripts": {
    "format": "npx --yes prettier -w .",
    "typecheck": "tsc --noEmit",
    "bddgen": "bddgen",
    "clean:reports": "node -e \"const fs = require('fs'); ['reports', 'screenshots'].forEach(d => { try { fs.rmSync(d, { recursive: true, force: true }); } catch (e) {} })\"",
    "test": "cross-env HEADLESS_MODE=true npx playwright test",
    "test:headed": "cross-env HEADLESS_MODE=false npx playwright test",
    "test:smoke": "cross-env HEADLESS_MODE=true npx playwright test --project=smoke",
    "test:smoke:headed": "cross-env HEADLESS_MODE=false npx playwright test --project=smoke",
    "test:all": "cross-env HEADLESS_MODE=true npx playwright test --project=all",
    "report": "npx playwright show-report reports/html"
  },
  "dependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.1",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "playwright-bdd": "^8.4.2",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}

